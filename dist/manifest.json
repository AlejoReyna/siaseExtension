{
  "manifest_version": 3,
  "name": "SIASE Plus",
  "version": "0.1.0",
  "description": "Modern UI, quick dashboard, grade alerts, calendar export, and smart navigation for UANL SIASE.",
  "action": {
    "default_title": "SIASE Plus",
    "default_popup": "src/popup/popup.html"
  },
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "background": {
    "service_worker": "service-worker-loader.js",
    "type": "module"
  },
  "permissions": [
    "alarms",
    "notifications",
    "storage",
    "downloads"
  ],
  "host_permissions": [
    "https://deimos.dgi.uanl.mx/*",
    "https://api.nexus.uanl.mx/*",
    "https://plataformanexus.uanl.mx/*"
  ],
  "content_scripts": [
    {
      "js": [
        "assets/frameset-injector.ts-loader-5OtxB-Ab.js"
      ],
      "matches": [
        "https://deimos.dgi.uanl.mx/*default.htm*"
      ],
      "all_frames": false,
      "run_at": "document_start"
    },
    {
      "js": [
        "assets/top-frame.ts-loader-DIEynoBW.js"
      ],
      "matches": [
        "https://deimos.dgi.uanl.mx/*maintop.htm*"
      ],
      "css": [
        "src/content/styles/top.css"
      ],
      "all_frames": true,
      "run_at": "document_idle"
    },
    {
      "js": [
        "assets/left-frame.ts-loader-BlXPgL07.js"
      ],
      "matches": [
        "https://deimos.dgi.uanl.mx/*mainleftdin01.htm*"
      ],
      "css": [
        "src/content/styles/left.css"
      ],
      "all_frames": true,
      "run_at": "document_idle"
    },
    {
      "js": [
        "assets/center-frame.ts-loader-5WqywlMp.js"
      ],
      "matches": [
        "https://deimos.dgi.uanl.mx/*maincenter.htm*"
      ],
      "css": [
        "src/content/styles/center.css"
      ],
      "all_frames": true,
      "run_at": "document_idle"
    },
    {
      "js": [
        "assets/career-landing.ts-loader-CG4HANVl.js"
      ],
      "matches": [
        "https://deimos.dgi.uanl.mx/cgi-bin/wspd_cgi.sh/eselcarrera.htm*"
      ],
      "css": [
        "src/content/styles/center.css"
      ],
      "all_frames": true,
      "run_at": "document_idle"
    },
    {
      "js": [
        "assets/nexus-session-capture.ts-p4vZVoWq.js"
      ],
      "matches": [
        "https://plataformanexus.uanl.mx/*"
      ],
      "all_frames": true,
      "run_at": "document_idle"
    },
    {
      "js": [
        "assets/router.ts-loader-dD5aupDj.js"
      ],
      "matches": [
        "https://deimos.dgi.uanl.mx/cgi-bin/wspd_cgi.sh/econcfs01.htm*",
        "https://deimos.dgi.uanl.mx/cgi-bin/wspd_cgi.sh/echalm01.htm*",
        "https://deimos.dgi.uanl.mx/cgi-bin/wspd_cgi.sh/econkdx01.htm*",
        "https://deimos.dgi.uanl.mx/cgi-bin/wspd_cgi.sh/edatal01.htm*",
        "https://deimos.dgi.uanl.mx/cgi-bin/wspd_cgi.sh/ecohoinsint01.htm*",
        "https://deimos.dgi.uanl.mx/cgi-bin/wspd_cgi.sh/ecSitEst01.htm*"
      ],
      "css": [
        "src/content/styles/center.css"
      ],
      "all_frames": true,
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "matches": [
        "https://deimos.dgi.uanl.mx/*"
      ],
      "resources": [
        "src/content/styles/shadow.css",
        "icons/*.png",
        "assets/single-view-layout-B_8o3koN.js",
        "assets/frameset-injector.ts-DLpfScJa.js",
        "assets/dom-DNG4d4nx.js",
        "assets/storage-CGf68QnW.js",
        "assets/top-frame.ts-CLybDx8z.js",
        "assets/jsx-runtime-18NIdeNA.js",
        "assets/menu-wWnSmKpE.js",
        "assets/left-frame.ts-Bt8Cf8GT.js",
        "assets/center-ui-JQ29ANvo.js",
        "assets/theme-PNjHhAdA.js",
        "assets/center-frame.ts-DtCRvd2p.js",
        "assets/kardex-2VjTFpTC.js",
        "assets/career-landing.ts-CvJ-5nk9.js"
      ],
      "use_dynamic_url": false
    },
    {
      "matches": [
        "https://plataformanexus.uanl.mx/*"
      ],
      "resources": [
        "assets/nexus-session-capture.ts-p4vZVoWq.js"
      ],
      "use_dynamic_url": false
    },
    {
      "matches": [
        "https://deimos.dgi.uanl.mx/*",
        "https://deimos.dgi.uanl.mx/*",
        "https://deimos.dgi.uanl.mx/*",
        "https://deimos.dgi.uanl.mx/*",
        "https://deimos.dgi.uanl.mx/*",
        "https://deimos.dgi.uanl.mx/*"
      ],
      "resources": [
        "assets/center-ui-JQ29ANvo.js",
        "assets/dom-DNG4d4nx.js",
        "assets/kardex-2VjTFpTC.js",
        "assets/storage-CGf68QnW.js",
        "assets/theme-PNjHhAdA.js",
        "assets/router.ts-DpH3_KC4.js"
      ],
      "use_dynamic_url": false
    }
  ]
}
