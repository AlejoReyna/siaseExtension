{
  "manifest_version": 3,
  "name": "Oh My SIASE",
  "version": "0.1.0",
  "description": "Un proyecto estudiantil para mejorar la experiencia de usuario de los alumnos de la UANL.",
  "action": {
    "default_title": "Oh My SIASE",
    "default_popup": "src/popup/popup.html"
  },
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "background": {
    "service_worker": "service-worker-loader.js",
    "type": "module"
  },
  "permissions": [
    "alarms",
    "notifications",
    "storage",
    "downloads"
  ],
  "host_permissions": [
    "https://deimos.dgi.uanl.mx/*",
    "https://api.nexus.uanl.mx/*",
    "https://plataformanexus.uanl.mx/*",
    "https://www.uanl.mx/*"
  ],
  "content_scripts": [
    {
      "js": [
        "assets/frameset-injector.ts-loader-OladEFjo.js"
      ],
      "matches": [
        "https://deimos.dgi.uanl.mx/*default.htm*"
      ],
      "all_frames": false,
      "run_at": "document_start"
    },
    {
      "js": [
        "assets/top-frame.ts-loader-BtnN5m20.js"
      ],
      "matches": [
        "https://deimos.dgi.uanl.mx/*maintop.htm*"
      ],
      "css": [
        "src/content/styles/top.css"
      ],
      "all_frames": true,
      "run_at": "document_idle"
    },
    {
      "js": [
        "assets/left-frame.ts-loader-DJyVz8h7.js"
      ],
      "matches": [
        "https://deimos.dgi.uanl.mx/*mainleftdin01.htm*"
      ],
      "css": [
        "src/content/styles/left.css"
      ],
      "all_frames": true,
      "run_at": "document_idle"
    },
    {
      "js": [
        "assets/center-frame.ts-loader-Bwwcr0dS.js"
      ],
      "matches": [
        "https://deimos.dgi.uanl.mx/*maincenter.htm*"
      ],
      "css": [
        "src/content/styles/center.css"
      ],
      "all_frames": true,
      "run_at": "document_idle"
    },
    {
      "js": [
        "assets/career-landing.ts-loader-BWJAFyeD.js"
      ],
      "matches": [
        "https://deimos.dgi.uanl.mx/cgi-bin/wspd_cgi.sh/eselcarrera.htm*"
      ],
      "css": [
        "src/content/styles/center.css"
      ],
      "all_frames": true,
      "run_at": "document_idle"
    },
    {
      "js": [
        "assets/nexus-session-capture.ts-DhWaTeFK.js"
      ],
      "matches": [
        "https://plataformanexus.uanl.mx/*"
      ],
      "all_frames": true,
      "run_at": "document_idle"
    },
    {
      "js": [
        "assets/router.ts-loader-DPCVcbNc.js"
      ],
      "matches": [
        "https://deimos.dgi.uanl.mx/cgi-bin/wspd_cgi.sh/econcfs01.htm*",
        "https://deimos.dgi.uanl.mx/cgi-bin/wspd_cgi.sh/echalm01.htm*",
        "https://deimos.dgi.uanl.mx/cgi-bin/wspd_cgi.sh/econkdx01.htm*",
        "https://deimos.dgi.uanl.mx/cgi-bin/wspd_cgi.sh/edatal01.htm*",
        "https://deimos.dgi.uanl.mx/cgi-bin/wspd_cgi.sh/ecohoinsint01.htm*",
        "https://deimos.dgi.uanl.mx/cgi-bin/wspd_cgi.sh/ecSitEst01.htm*"
      ],
      "css": [
        "src/content/styles/center.css"
      ],
      "all_frames": true,
      "run_at": "document_idle"
    },
    {
      "js": [
        "assets/gym-reservation-page.ts-loader-eoUsAL9U.js"
      ],
      "matches": [
        "https://deimos.dgi.uanl.mx/cgi-bin/wspd_cgi.sh/CdGymins01.htm*"
      ],
      "css": [
        "src/content/styles/center.css"
      ],
      "all_frames": true,
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "matches": [
        "https://deimos.dgi.uanl.mx/*"
      ],
      "resources": [
        "src/content/styles/shadow.css",
        "icons/*.png",
        "assets/single-view-layout-CYTgkO3R.js",
        "assets/center-layout-debug-DlPHY3jT.js",
        "assets/frameset-injector.ts-DhJllhtc.js",
        "assets/student-DzLPJtzr.js",
        "assets/storage-DPPjqHu1.js",
        "assets/dom-DsnxF-Y-.js",
        "assets/top-frame.ts-Bhhpwd1Q.js",
        "assets/jsx-runtime-CpzHkGBj.js",
        "assets/menu-DGbmQSXp.js",
        "assets/left-frame.ts-BPqfb2iU.js",
        "assets/center-ui-ri9NULPS.js",
        "assets/theme-Bra8ghU2.js",
        "assets/center-frame.ts-BCSqQaaU.js",
        "assets/kardex-oL6Gt3ZT.js",
        "assets/career-landing.ts-DU5-9e5M.js",
        "assets/gym-reservation-page.ts-Cdk9y5LA.js"
      ],
      "use_dynamic_url": false
    },
    {
      "matches": [
        "https://plataformanexus.uanl.mx/*"
      ],
      "resources": [
        "assets/nexus-session-capture.ts-DhWaTeFK.js"
      ],
      "use_dynamic_url": false
    },
    {
      "matches": [
        "https://deimos.dgi.uanl.mx/*",
        "https://deimos.dgi.uanl.mx/*",
        "https://deimos.dgi.uanl.mx/*",
        "https://deimos.dgi.uanl.mx/*",
        "https://deimos.dgi.uanl.mx/*",
        "https://deimos.dgi.uanl.mx/*"
      ],
      "resources": [
        "assets/center-ui-ri9NULPS.js",
        "assets/dom-DsnxF-Y-.js",
        "assets/kardex-oL6Gt3ZT.js",
        "assets/storage-DPPjqHu1.js",
        "assets/center-layout-debug-DlPHY3jT.js",
        "assets/theme-Bra8ghU2.js",
        "assets/router.ts-or6HBWy-.js"
      ],
      "use_dynamic_url": false
    }
  ]
}
