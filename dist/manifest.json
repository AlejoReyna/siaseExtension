{
  "manifest_version": 3,
  "name": "Oh My SIASE",
  "version": "0.1.0",
  "description": "Un proyecto estudiantil para mejorar la experiencia de usuario de los alumnos de la UANL.",
  "action": {
    "default_title": "Oh My SIASE",
    "default_popup": "src/popup/popup.html"
  },
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "background": {
    "service_worker": "service-worker-loader.js",
    "type": "module"
  },
  "permissions": [
    "alarms",
    "notifications",
    "storage",
    "downloads"
  ],
  "host_permissions": [
    "https://deimos.dgi.uanl.mx/*",
    "https://api.nexus.uanl.mx/*",
    "https://plataformanexus.uanl.mx/*"
  ],
  "content_scripts": [
    {
      "js": [
        "assets/frameset-injector.ts-loader-BUhGRCP6.js"
      ],
      "matches": [
        "https://deimos.dgi.uanl.mx/*default.htm*"
      ],
      "all_frames": false,
      "run_at": "document_start"
    },
    {
      "js": [
        "assets/top-frame.ts-loader-BJhe4ON0.js"
      ],
      "matches": [
        "https://deimos.dgi.uanl.mx/*maintop.htm*"
      ],
      "css": [
        "src/content/styles/top.css"
      ],
      "all_frames": true,
      "run_at": "document_idle"
    },
    {
      "js": [
        "assets/left-frame.ts-loader-Cum-hTzW.js"
      ],
      "matches": [
        "https://deimos.dgi.uanl.mx/*mainleftdin01.htm*"
      ],
      "css": [
        "src/content/styles/left.css"
      ],
      "all_frames": true,
      "run_at": "document_idle"
    },
    {
      "js": [
        "assets/center-frame.ts-loader-CvOjBA7c.js"
      ],
      "matches": [
        "https://deimos.dgi.uanl.mx/*maincenter.htm*"
      ],
      "css": [
        "src/content/styles/center.css"
      ],
      "all_frames": true,
      "run_at": "document_idle"
    },
    {
      "js": [
        "assets/career-landing.ts-loader-BtKRxZqA.js"
      ],
      "matches": [
        "https://deimos.dgi.uanl.mx/cgi-bin/wspd_cgi.sh/eselcarrera.htm*"
      ],
      "css": [
        "src/content/styles/center.css"
      ],
      "all_frames": true,
      "run_at": "document_idle"
    },
    {
      "js": [
        "assets/nexus-session-capture.ts-ChMJI15n.js"
      ],
      "matches": [
        "https://plataformanexus.uanl.mx/*"
      ],
      "all_frames": true,
      "run_at": "document_idle"
    },
    {
      "js": [
        "assets/router.ts-loader-Biifvcik.js"
      ],
      "matches": [
        "https://deimos.dgi.uanl.mx/cgi-bin/wspd_cgi.sh/econcfs01.htm*",
        "https://deimos.dgi.uanl.mx/cgi-bin/wspd_cgi.sh/echalm01.htm*",
        "https://deimos.dgi.uanl.mx/cgi-bin/wspd_cgi.sh/econkdx01.htm*",
        "https://deimos.dgi.uanl.mx/cgi-bin/wspd_cgi.sh/edatal01.htm*",
        "https://deimos.dgi.uanl.mx/cgi-bin/wspd_cgi.sh/ecohoinsint01.htm*",
        "https://deimos.dgi.uanl.mx/cgi-bin/wspd_cgi.sh/ecSitEst01.htm*"
      ],
      "css": [
        "src/content/styles/center.css"
      ],
      "all_frames": true,
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "matches": [
        "https://deimos.dgi.uanl.mx/*"
      ],
      "resources": [
        "src/content/styles/shadow.css",
        "icons/*.png",
        "assets/single-view-layout-CbW7mO8X.js",
        "assets/center-layout-debug-bD1CAdlR.js",
        "assets/frameset-injector.ts-BbeVgwjl.js",
        "assets/dom-DNG4d4nx.js",
        "assets/storage-CmabcgjT.js",
        "assets/top-frame.ts-CzOKuPic.js",
        "assets/jsx-runtime-18NIdeNA.js",
        "assets/menu-wWnSmKpE.js",
        "assets/left-frame.ts-C7flgLdC.js",
        "assets/center-ui--v-JpTKS.js",
        "assets/theme-PNjHhAdA.js",
        "assets/center-frame.ts-D55DnxMS.js",
        "assets/kardex-D2H372DB.js",
        "assets/career-landing.ts-B8hBydSF.js"
      ],
      "use_dynamic_url": false
    },
    {
      "matches": [
        "https://plataformanexus.uanl.mx/*"
      ],
      "resources": [
        "assets/nexus-session-capture.ts-ChMJI15n.js"
      ],
      "use_dynamic_url": false
    },
    {
      "matches": [
        "https://deimos.dgi.uanl.mx/*",
        "https://deimos.dgi.uanl.mx/*",
        "https://deimos.dgi.uanl.mx/*",
        "https://deimos.dgi.uanl.mx/*",
        "https://deimos.dgi.uanl.mx/*",
        "https://deimos.dgi.uanl.mx/*"
      ],
      "resources": [
        "assets/center-ui--v-JpTKS.js",
        "assets/dom-DNG4d4nx.js",
        "assets/kardex-D2H372DB.js",
        "assets/storage-CmabcgjT.js",
        "assets/center-layout-debug-bD1CAdlR.js",
        "assets/theme-PNjHhAdA.js",
        "assets/router.ts-C1WyiT8N.js"
      ],
      "use_dynamic_url": false
    }
  ]
}
