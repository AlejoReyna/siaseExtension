{
  "manifest_version": 3,
  "name": "Oh My SIASE",
  "version": "0.1.0",
  "description": "Un proyecto estudiantil para mejorar la experiencia de usuario de los alumnos de la UANL.",
  "action": {
    "default_title": "Oh My SIASE",
    "default_popup": "src/popup/popup.html"
  },
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "background": {
    "service_worker": "service-worker-loader.js",
    "type": "module"
  },
  "permissions": [
    "alarms",
    "notifications",
    "storage",
    "downloads"
  ],
  "host_permissions": [
    "https://deimos.dgi.uanl.mx/*",
    "https://api.nexus.uanl.mx/*",
    "https://plataformanexus.uanl.mx/*"
  ],
  "content_scripts": [
    {
      "js": [
        "assets/frameset-injector.ts-loader-BmNJFjp-.js"
      ],
      "matches": [
        "https://deimos.dgi.uanl.mx/*default.htm*"
      ],
      "all_frames": false,
      "run_at": "document_start"
    },
    {
      "js": [
        "assets/top-frame.ts-loader-rgr9gZT6.js"
      ],
      "matches": [
        "https://deimos.dgi.uanl.mx/*maintop.htm*"
      ],
      "css": [
        "src/content/styles/top.css"
      ],
      "all_frames": true,
      "run_at": "document_idle"
    },
    {
      "js": [
        "assets/left-frame.ts-loader-CpGWqOC9.js"
      ],
      "matches": [
        "https://deimos.dgi.uanl.mx/*mainleftdin01.htm*"
      ],
      "css": [
        "src/content/styles/left.css"
      ],
      "all_frames": true,
      "run_at": "document_idle"
    },
    {
      "js": [
        "assets/center-frame.ts-loader-B_Bmtmdc.js"
      ],
      "matches": [
        "https://deimos.dgi.uanl.mx/*maincenter.htm*"
      ],
      "css": [
        "src/content/styles/center.css"
      ],
      "all_frames": true,
      "run_at": "document_idle"
    },
    {
      "js": [
        "assets/career-landing.ts-loader-E_jQYFo3.js"
      ],
      "matches": [
        "https://deimos.dgi.uanl.mx/cgi-bin/wspd_cgi.sh/eselcarrera.htm*"
      ],
      "css": [
        "src/content/styles/center.css"
      ],
      "all_frames": true,
      "run_at": "document_idle"
    },
    {
      "js": [
        "assets/nexus-session-capture.ts-CpYH3Iwx.js"
      ],
      "matches": [
        "https://plataformanexus.uanl.mx/*"
      ],
      "all_frames": true,
      "run_at": "document_idle"
    },
    {
      "js": [
        "assets/router.ts-loader-CYnBS-Ox.js"
      ],
      "matches": [
        "https://deimos.dgi.uanl.mx/cgi-bin/wspd_cgi.sh/econcfs01.htm*",
        "https://deimos.dgi.uanl.mx/cgi-bin/wspd_cgi.sh/echalm01.htm*",
        "https://deimos.dgi.uanl.mx/cgi-bin/wspd_cgi.sh/econkdx01.htm*",
        "https://deimos.dgi.uanl.mx/cgi-bin/wspd_cgi.sh/edatal01.htm*",
        "https://deimos.dgi.uanl.mx/cgi-bin/wspd_cgi.sh/ecohoinsint01.htm*",
        "https://deimos.dgi.uanl.mx/cgi-bin/wspd_cgi.sh/ecSitEst01.htm*"
      ],
      "css": [
        "src/content/styles/center.css"
      ],
      "all_frames": true,
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "matches": [
        "https://deimos.dgi.uanl.mx/*"
      ],
      "resources": [
        "src/content/styles/shadow.css",
        "icons/*.png",
        "assets/single-view-layout-Cb-1EJGK.js",
        "assets/center-layout-debug-BsmNkshu.js",
        "assets/frameset-injector.ts-D3XCTXtH.js",
        "assets/dom-DsnxF-Y-.js",
        "assets/storage-DPPjqHu1.js",
        "assets/top-frame.ts-CXPeKro6.js",
        "assets/jsx-runtime-CpzHkGBj.js",
        "assets/menu-BPIw1x24.js",
        "assets/left-frame.ts-C4VO03A0.js",
        "assets/center-ui-BXno3GP1.js",
        "assets/theme-CCGzrRdb.js",
        "assets/center-frame.ts-2AZizoLp.js",
        "assets/kardex-GQB9uhsr.js",
        "assets/career-landing.ts-DYaE1u9i.js"
      ],
      "use_dynamic_url": false
    },
    {
      "matches": [
        "https://plataformanexus.uanl.mx/*"
      ],
      "resources": [
        "assets/nexus-session-capture.ts-CpYH3Iwx.js"
      ],
      "use_dynamic_url": false
    },
    {
      "matches": [
        "https://deimos.dgi.uanl.mx/*",
        "https://deimos.dgi.uanl.mx/*",
        "https://deimos.dgi.uanl.mx/*",
        "https://deimos.dgi.uanl.mx/*",
        "https://deimos.dgi.uanl.mx/*",
        "https://deimos.dgi.uanl.mx/*"
      ],
      "resources": [
        "assets/center-ui-BXno3GP1.js",
        "assets/dom-DsnxF-Y-.js",
        "assets/kardex-GQB9uhsr.js",
        "assets/storage-DPPjqHu1.js",
        "assets/center-layout-debug-BsmNkshu.js",
        "assets/theme-CCGzrRdb.js",
        "assets/router.ts-CwQ0zlZx.js"
      ],
      "use_dynamic_url": false
    }
  ]
}
